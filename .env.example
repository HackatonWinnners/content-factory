# Hackathon required: GEMINI_API_KEY, TAVILY_API_KEY, GRADIUM_API_KEY. Others can stay placeholder for the demo.

# Google Gemini — script writing via AI SDK (`gemini-2.5-flash`)
GEMINI_API_KEY=
# Tavily — market context search for editorial step
TAVILY_API_KEY=
# Gradium — TTS voiceover on the result screen
GRADIUM_API_KEY=
# Hera — visual scene generation (placeholder OK for hackathon demo)
HERA_API_KEY=
# Pioneer / Fastino — fact extraction (placeholder OK for hackathon demo)
PIONEER_API_KEY=

# Postgres — local docker compose default; not required for demo flow
DATABASE_URL=postgresql://postgres:password@localhost:5432/content-factory
# CORS origin for the web app calling the Hono server
CORS_ORIGIN=http://localhost:3001
# Public base URL the web app uses to reach the server
NEXT_PUBLIC_SERVER_URL=http://localhost:3000
# Node environment — leave development unless deploying
NODE_ENV=development
